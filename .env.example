# ============================================
# RAILWAY DEPLOYMENT - ENVIRONMENT
# ============================================

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=${RAILWAY_PUBLIC_DOMAIN}
APP_NAME=OngonDropshipAPI

# Security (Railway Variables te set koro)
JWT_SECRET=${JWT_SECRET}
JWT_ISSUER=${RAILWAY_PUBLIC_DOMAIN}
JWT_AUDIENCE=reseller-app
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

HMAC_SECRET=${HMAC_SECRET}
API_KEY_SALT=${API_KEY_SALT}

# Encryption
AES_KEY=${AES_KEY}
AES_IV=${AES_IV}

# Rate Limiting
RATE_LIMIT_IP=60
RATE_LIMIT_WINDOW=60
RATE_LIMIT_API_KEY=1000
RATE_LIMIT_API_WINDOW=3600

# WooCommerce API (Backend)
WC_URL=${WC_URL}
WC_CONSUMER_KEY=${WC_CONSUMER_KEY}
WC_CONSUMER_SECRET=${WC_CONSUMER_SECRET}
WC_VERSION=wc/v3
WC_TIMEOUT=30

# Database (Railway auto provides)
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_NAME=${MYSQLDATABASE}
DB_USER=${MYSQLUSER}
DB_PASS=${MYSQLPASSWORD}
DB_CHARSET=utf8mb4

# Redis (Railway auto provides)
REDIS_HOST=${REDISHOST}
REDIS_PORT=${REDISPORT}
REDIS_PASSWORD=${REDISPASSWORD}
REDIS_DB=0

# CORS
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key,X-HMAC-Signature,X-Request-ID
CORS_MAX_AGE=86400

# Admin IPs (Railway er IP dynamic, tai * rakho)
ADMIN_IPS=*

# Logging
LOG_LEVEL=warning
LOG_RETENTION_DAYS=30

# Discord (optional)
DISCORD_WEBHOOK_URL=${DISCORD_WEBHOOK_URL}