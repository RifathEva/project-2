# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-project.railway.app
APP_NAME=OngonDropshipAPI

# Security (generate strong random values)
JWT_SECRET=your-256-bit-secret-key-here-min-32-chars
JWT_ISSUER=your-project.railway.app
JWT_AUDIENCE=reseller-app
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

HMAC_SECRET=your-hmac-secret-key-different-from-jwt
API_KEY_SALT=unique-salt-for-api-key-hashing

# Encryption
AES_KEY=32-byte-encryption-key-here!!!
AES_IV=16-byte-iv-here!!

# Rate Limiting
RATE_LIMIT_IP=60
RATE_LIMIT_WINDOW=60
RATE_LIMIT_API_KEY=1000
RATE_LIMIT_API_WINDOW=3600

# WooCommerce API (Backend)
WC_URL=https://ongonwear.is-best.net
WC_CONSUMER_KEY=ck_your_consumer_key
WC_CONSUMER_SECRET=cs_your_consumer_secret
WC_VERSION=wc/v3
WC_TIMEOUT=30

# Database (Railway auto provides)
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_NAME=${MYSQLDATABASE}
DB_USER=${MYSQLUSER}
DB_PASS=${MYSQLPASSWORD}
DB_CHARSET=utf8mb4

# Redis (Railway auto provides)
REDIS_HOST=${REDISHOST}
REDIS_PORT=${REDISPORT}
REDIS_PASSWORD=${REDISPASSWORD}
REDIS_DB=0

# CORS
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key,X-HMAC-Signature,X-Request-ID
CORS_MAX_AGE=86400

# Admin
ADMIN_IPS=*

# Logging
LOG_LEVEL=warning
LOG_RETENTION_DAYS=30

# Discord (optional)
DISCORD_WEBHOOK_URL=
